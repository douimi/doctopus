# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# Postgres (from Supabase). Use the pooler URL for the app and the direct URL for migrations.
DATABASE_URL=postgresql://postgres:PASS@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL_DIRECT=postgresql://postgres:PASS@db.YOUR-PROJECT.supabase.co:5432/postgres

# App
APP_URL=http://localhost:3000
CRON_SECRET=replace-me-with-a-long-random-string

# Sentry (optional — leave blank locally; set in Vercel for production)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# AI providers (optional — only set the ones whose tenants you'll route to)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
